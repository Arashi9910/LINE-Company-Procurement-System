FROM mcr.microsoft.com/playwright:v1.61.0-noble

ENV NODE_ENV=production
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

WORKDIR /app

COPY jobs/flyingmouse/package.json jobs/flyingmouse/package-lock.json ./
RUN npm ci --omit=dev

COPY src/flyingmouse ./src/flyingmouse
COPY scripts/flyingmouse-sync.mjs scripts/flyingmouse-inventory-writeback.mjs scripts/flyingmouse-combined-job.mjs ./scripts/

USER pwuser

CMD ["node", "scripts/flyingmouse-combined-job.mjs"]
